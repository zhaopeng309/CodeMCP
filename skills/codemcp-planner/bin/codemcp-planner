#!/bin/bash
# codemcp-planner - CodeMCP Planner 主命令行工具

set -e

# 版本信息
VERSION="1.0.0"
AUTHOR="OpenClaw AI"
LICENSE="MIT"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 日志函数
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_debug() { [ "${DEBUG:-false}" = "true" ] && echo -e "${MAGENTA}[DEBUG]${NC} $1"; }

# 获取脚本目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
SCRIPTS_DIR="$PROJECT_ROOT/scripts"

# 检查脚本目录
check_scripts_dir() {
    if [ ! -d "$SCRIPTS_DIR" ]; then
        log_error "脚本目录不存在: $SCRIPTS_DIR"
        exit 1
    fi
}

# 显示横幅
show_banner() {
    cat << "EOF"
  ____          _        ____  _                           
 / ___|___   __| | ___  |  _ \| | __ _ _ __  _ __   ___ _ __ 
| |   / _ \ / _` |/ _ \ | |_) | |/ _` | '_ \| '_ \ / _ \ '__|
| |__| (_) | (_| |  __/ |  __/| | (_| | | | | | | |  __/ |   
 \____\___/ \__,_|\___| |_|   |_|\__,_|_| |_|_| |_|\___|_|   
                                                             
EOF
    echo -e "${CYAN}CodeMCP Planner - AI协同设计规划器${NC}"
    echo -e "${YELLOW}版本: $VERSION${NC}"
    echo ""
}

# 显示帮助
show_help() {
    show_banner
    cat << EOF
用法: codemcp-planner [命令] [选项]

命令:
  plan        计划管理
    create    创建新计划
    list      列出所有计划
    show      查看计划详情
    validate  验证计划文件

  workflow    工作流管理
    start     启动工作流
    stop      停止工作流
    status    查看工作流状态
    restart   重启工作流

  monitor     监控管理
    start     启动监控
    stop      停止监控
    status    查看监控状态
    logs      查看监控日志

  report      报告管理
    generate  生成报告
    history   查看历史报告
    export    导出报告

  config      配置管理
    show      显示配置
    set       设置配置
    init      初始化配置
    validate  验证配置

  check       环境检查
    all       完整环境检查
    services  服务检查
    git       Git检查
    codemcp   CodeMCP检查

  problem     问题管理
    report    报告问题
    list      列出问题
    show      查看问题详情

  interactive 交互式模式
  version     显示版本信息
  help        显示帮助信息

选项:
  -h, --help     显示帮助信息
  -v, --version  显示版本信息
  -d, --debug    调试模式
  -q, --quiet    安静模式

示例:
  codemcp-planner plan create --name "我的项目"
  codemcp-planner workflow start --plan plan.json
  codemcp-planner monitor start --interval 30
  codemcp-planner check all
  codemcp-planner interactive

环境变量:
  CODEMCP_PATH    CodeMCP安装路径
  GIT_USER_NAME   Git用户名
  GIT_USER_EMAIL  Git邮箱
  DEBUG          启用调试模式

文档: 查看 README.md 和 docs/ 目录
支持: 使用 'problem report' 命令报告问题
EOF
}

# 显示版本
show_version() {
    show_banner
    cat << EOF
版本: $VERSION
作者: $AUTHOR
许可证: $LICENSE
项目: CodeMCP Planner Skill
路径: $PROJECT_ROOT

组件:
  主脚本: $0
  脚本目录: $SCRIPTS_DIR
  示例目录: $PROJECT_ROOT/examples
  文档目录: $PROJECT_ROOT/docs

依赖:
  CodeMCP: $(command -v codemcp >/dev/null 2>&1 && echo "已安装" || echo "未安装")
  Git: $(command -v git >/dev/null 2>&1 && echo "已安装" || echo "未安装")
  Python3: $(command -v python3 >/dev/null 2>&1 && echo "已安装" || echo "未安装")

环境:
  CODEMCP_PATH: ${CODEMCP_PATH:-未设置}
  工作目录: $(pwd)
  用户: $(whoami)
  主机: $(hostname)
EOF
}

# 计划管理
plan_management() {
    local subcommand="$1"
    shift
    
    case "$subcommand" in
        create)
            log_info "创建新计划..."
            "$SCRIPTS_DIR/create_plan_template.sh" "$@"
            ;;
        list)
            log_info "列出计划..."
            find . -name "*_plan.json" -o -name "*_plan.yaml" -o -name "*_plan.yml" 2>/dev/null | head -20
            ;;
        show)
            local plan_file="$1"
            if [ -z "$plan_file" ]; then
                log_error "请指定计划文件"
                exit 1
            fi
            if [ -f "$plan_file" ]; then
                log_info "显示计划: $plan_file"
                cat "$plan_file"
            else
                log_error "计划文件不存在: $plan_file"
                exit 1
            fi
            ;;
        validate)
            local plan_file="$1"
            if [ -z "$plan_file" ]; then
                log_error "请指定计划文件"
                exit 1
            fi
            log_info "验证计划: $plan_file"
            if command -v python3 >/dev/null 2>&1; then
                python3 -m json.tool "$plan_file" >/dev/null && log_success "JSON格式正确" || log_error "JSON格式错误"
            else
                log_warning "Python3未安装，跳过JSON验证"
            fi
            ;;
        *)
            log_error "未知的子命令: $subcommand"
            echo "可用子命令: create, list, show, validate"
            exit 1
            ;;
    esac
}

# 工作流管理
workflow_management() {
    local subcommand="$1"
    shift
    
    case "$subcommand" in
        start)
            log_info "启动工作流..."
            "$SCRIPTS_DIR/codemcp_planner.sh" start "$@"
            ;;
        stop)
            log_info "停止工作流..."
            "$SCRIPTS_DIR/codemcp_planner.sh" stop "$@"
            ;;
        status)
            log_info "工作流状态..."
            "$SCRIPTS_DIR/codemcp_planner.sh" status "$@"
            ;;
        restart)
            log_info "重启工作流..."
            "$SCRIPTS_DIR/codemcp_planner.sh" stop "$@"
            sleep 2
            "$SCRIPTS_DIR/codemcp_planner.sh" start "$@"
            ;;
        *)
            log_error "未知的子命令: $subcommand"
            echo "可用子命令: start, stop, status, restart"
            exit 1
            ;;
    esac
}

# 监控管理
monitor_management() {
    local subcommand="$1"
    shift
    
    case "$subcommand" in
        start)
            log_info "启动监控..."
            "$SCRIPTS_DIR/monitor_tasks.sh" "$@"
            ;;
        stop)
            log_info "停止监控..."
            pkill -f "monitor_tasks.sh" 2>/dev/null && log_success "监控已停止" || log_warning "未找到监控进程"
            ;;
        status)
            log_info "监控状态..."
            if ps aux | grep -v grep | grep -q "monitor_tasks.sh"; then
                log_success "监控正在运行"
            else
                log_info "监控未运行"
            fi
            ;;
        logs)
            log_info "监控日志..."
            tail -f /tmp/codemcp_monitor.log 2>/dev/null || echo "日志文件不存在"
            ;;
        *)
            log_error "未知的子命令: $subcommand"
            echo "可用子命令: start, stop, status, logs"
            exit 1
            ;;
    esac
}

# 报告管理
report_management() {
    local subcommand="$1"
    shift
    
    case "$subcommand" in
        generate)
            log_info "生成报告..."
            "$SCRIPTS_DIR/generate_report.sh" "$@"
            ;;
        history)
            log_info "历史报告..."
            find . -name "progress_report_*.md" -o -name "progress_report_*.html" 2>/dev/null | sort -r | head -10
            ;;
        export)
            local report_file="$1"
            local format="${2:-markdown}"
            if [ -z "$report_file" ]; then
                log_error "请指定报告文件"
                exit 1
            fi
            log_info "导出报告: $report_file -> $format"
            # 这里可以添加格式转换逻辑
            cat "$report_file"
            ;;
        *)
            log_error "未知的子命令: $subcommand"
            echo "可用子命令: generate, history, export"
            exit 1
            ;;
    esac
}

# 配置管理
config_management() {
    local subcommand="$1"
    shift
    
    local config_dir="$HOME/.config/codemcp-planner"
    local config_file="$config_dir/config.json"
    
    case "$subcommand" in
        show)
            log_info "显示配置..."
            if [ -f "$config_file" ]; then
                cat "$config_file"
            else
                log_info "配置文件不存在: $config_file"
                echo "使用默认配置"
            fi
            ;;
        set)
            local key="$1"
            local value="$2"
            if [ -z "$key" ] || [ -z "$value" ]; then
                log_error "使用方法: config set <key> <value>"
                exit 1
            fi
            log_info "设置配置: $key = $value"
            mkdir -p "$config_dir"
            if [ ! -f "$config_file" ]; then
                echo "{}" > "$config_file"
            fi
            # 简单的JSON更新（实际项目应该使用jq）
            echo "警告: JSON更新需要jq命令，这里仅显示信息"
            echo "请手动编辑: $config_file"
            ;;
        init)
            log_info "初始化配置..."
            mkdir -p "$config_dir"
            if [ ! -f "$config_file" ]; then
                cat > "$config_file" << EOF
{
  "codemcp": {
    "path": "${CODEMCP_PATH:-/home/designer/tools/CodeMCP}",
    "host": "localhost",
    "port": 8000
  },
  "git": {
    "user_name": "${GIT_USER_NAME:-AI Developer}",
    "user_email": "${GIT_USER_EMAIL:-ai.developer@codemcp.ai}",
    "auto_commit": true
  },
  "monitoring": {
    "interval": 30,
    "alert_on_failure": true
  }
}
EOF
                log_success "配置文件已创建: $config_file"
            else
                log_warning "配置文件已存在: $config_file"
            fi
            ;;
        validate)
            log_info "验证配置..."
            if [ -f "$config_file" ]; then
                if command -v python3 >/dev/null 2>&1; then
                    python3 -m json.tool "$config_file" >/dev/null && log_success "配置格式正确" || log_error "配置格式错误"
                else
                    log_warning "Python3未安装，跳过JSON验证"
                fi
            else
                log_info "配置文件不存在，使用默认配置"
            fi
            ;;
        *)
            log_error "未知的子命令: $subcommand"
            echo "可用子命令: show, set, init, validate"
            exit 1
            ;;
    esac
}

# 环境检查
check_environment() {
    local subcommand="$1"
    
    case "$subcommand" in
        all)
            log_info "完整环境检查..."
            "$SCRIPTS_DIR/check_environment.sh" --all
            ;;
        services)
            log_info "服务检查..."
            "$SCRIPTS_DIR/check_environment.sh" --services
            ;;
        git)
            log_info "Git检查..."
            "$SCRIPTS_DIR/check_environment.sh" --git
            ;;
        codemcp)
            log_info "CodeMCP检查..."
            "$SCRIPTS_DIR/check_environment.sh" --codemcp
            ;;
        *)
            log_info "环境检查..."
            "$SCRIPTS_DIR/check_environment.sh" "$@"
            ;;
    esac
}

# 问题管理
problem_management() {
    local subcommand="$1"
    shift
    
    case "$subcommand" in
        report)
            log_info "报告问题..."
            "$SCRIPTS_DIR/problem_report.sh" "$@"
            ;;
        list)
            log_info "列出问题..."
            find . -name "problem_report_*.md" 2>/dev/null | sort -r | head -10
            ;;
        show)
            local problem_file="$1"
            if [ -z "$problem_file" ]; then
                log_error "请指定问题文件"
                exit 1
            fi
            if [ -f "$problem_file" ]; then
                cat "$problem_file"
            else
                log_error "问题文件不存在: $problem_file"
                exit 1
            fi
            ;;
        *)
            log_error "未知的子命令: $subcommand"
            echo "可用子命令: report, list, show"
            exit 1
            ;;
    esac
}

# 交互式模式
interactive_mode() {
    log_info "启动交互式模式..."
    "$SCRIPTS_DIR/codemcp_planner.sh" menu
}

# 主函数
main() {
    # 检查脚本目录
    check_scripts_dir
    
    # 处理选项
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            -d|--debug)
                DEBUG="true"
                shift
                ;;
            -q|--quiet)
                # 安静模式 - 减少输出
                exec >/dev/null 2>&1
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    # 获取命令
    local command="$1"
    shift
    
    # 执行命令
    case "$command" in
        plan)
            plan_management "$@"
            ;;
        workflow)
            workflow_management "$@"
            ;;
        monitor)
            monitor_management "$@"
            ;;
        report)
            report_management "$@"
            ;;
        config)
            config_management "$@"
            ;;
        check)
            check_environment "$@"
            ;;
        problem)
            problem_management "$@"
            ;;
        interactive)
            interactive_mode "$@"
            ;;
        version)
            show_version
            ;;
        help)
            show_help
            ;;
        "")
            show_help
            ;;
        *)
            log_error "未知的命令: $command"
            show_help
            exit 1
            ;;
    esac
}

# 运行主函数
main "$@"