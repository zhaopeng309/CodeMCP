# CodeMCP 环境配置模板
# 复制此文件为 .env 并根据需要修改配置

# 数据库配置
# 支持 SQLite、PostgreSQL、MySQL 等
# 示例: sqlite:///./codemcp.db
# 示例: postgresql://user:password@localhost:5432/codemcp
DATABASE_URL=sqlite:///./codemcp.db

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# API 配置
API_PREFIX=/api/v1
# CORS 允许的来源，多个用逗号分隔或 JSON 数组格式
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# 任务执行配置
TASK_WINDOW_SIZE=5
MAX_RETRIES=3
DEFAULT_PRIORITY=0

# 日志配置
# LOG_FILE=/var/log/codemcp/app.log
LOG_FORMAT=json

# MCP 服务器配置 (可选)
# MCP_PLANNER_URL=http://localhost:8001
# MCP_EXECUTOR_URL=http://localhost:8002

# 生产环境安全配置
# SECRET_KEY=your-secret-key-here-change-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=30