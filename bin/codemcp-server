#!/usr/bin/env python3
"""
CodeMCP API服务器启动脚本

启动FastAPI Gateway服务器，提供REST API接口。
支持参数：--host, --port, --reload
"""

import sys
import os
import argparse

# 添加项目根目录到Python路径
project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, project_root)

def parse_args():
    """解析命令行参数"""
    parser = argparse.ArgumentParser(
        description="CodeMCP API服务器启动脚本",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  %(prog)s                    # 使用默认配置启动
  %(prog)s --host 127.0.0.1   # 指定主机
  %(prog)s --port 8080        # 指定端口
  %(prog)s --reload           # 开发模式热重载
        """
    )
    
    parser.add_argument(
        "--host",
        default="0.0.0.0",
        help="监听主机地址 (默认: 0.0.0.0)"
    )
    
    parser.add_argument(
        "--port",
        type=int,
        default=8000,
        help="监听端口 (默认: 8000)"
    )
    
    parser.add_argument(
        "--reload",
        action="store_true",
        help="开发模式热重载"
    )
    
    return parser.parse_args()

def main():
    """主函数"""
    args = parse_args()
    
    print("启动CodeMCP API服务器...")
    print(f"项目根目录: {project_root}")
    print(f"监听地址: {args.host}:{args.port}")
    print(f"热重载模式: {'启用' if args.reload else '禁用'}")
    print("按Ctrl+C停止服务器")
    print("-" * 60)
    
    try:
        # 导入并运行uvicorn
        import uvicorn
        from src.codemcp.api.server import app
        
        uvicorn.run(
            app,
            host=args.host,
            port=args.port,
            reload=args.reload,
            log_level="info"
        )
    except KeyboardInterrupt:
        print("\n服务器已停止")
    except Exception as e:
        print(f"服务器启动失败: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()