#!/usr/bin/env python3
"""
CodeMCP 命令行工具

统一的CodeMCP命令行接口，提供所有管理功能。
"""

import sys
import os

# 添加项目根目录到Python路径
project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, project_root)

def main():
    """主函数"""
    # 检查是否提供了子命令
    if len(sys.argv) == 1:
        # 没有参数，启动交互式控制台
        print("启动CodeMCP交互式控制台...")
        print("输入 'help' 查看可用命令")
        print("输入 'exit' 或 'quit' 退出")
        print("-" * 60)
        
        from src.codemcp.cli.console import run_console
        run_console()
        return
    
    # 有参数，传递给实际的CLI
    try:
        from src.codemcp.cli.main import app
        app()
    except SystemExit:
        # Typer会调用sys.exit()，我们捕获它
        pass
    except Exception as e:
        print(f"错误: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()