#!/usr/bin/env bash

# CodeMCP 命令行工具
#
# 统一的CodeMCP命令行接口，提供所有管理功能。
# 自动激活虚拟环境。

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# 检查虚拟环境是否存在
VENV_PATH="$PROJECT_ROOT/venv"
if [ -d "$VENV_PATH" ]; then
    # 激活虚拟环境
    source "$VENV_PATH/bin/activate"
else
    echo "警告: 虚拟环境不存在于 $VENV_PATH"
    echo "请先创建虚拟环境: python3 -m venv venv"
    echo "然后安装依赖: pip install -e ."
fi

# 执行Python脚本
cd "$PROJECT_ROOT"
exec python3 -m src.codemcp.cli.main "$@"