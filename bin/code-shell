#!/usr/bin/env python3
"""
CodeMCP Shell - 交互式命令执行环境

一个简单的交互式shell，提供code-shell>提示符，
用于执行CodeMCP相关命令。
"""

import sys
import os
import subprocess
import readline
import atexit
from typing import List, Optional

# 添加项目根目录到 Python 路径
project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, project_root)

def check_and_use_venv():
    """检查并尝试使用虚拟环境"""
    venv_python = os.path.join(project_root, "venv", "bin", "python")
    
    # 如果虚拟环境存在且当前不在虚拟环境中，建议使用它
    if os.path.exists(venv_python) and "VIRTUAL_ENV" not in os.environ:
        print("检测到虚拟环境但未激活。")
        print("正在尝试使用虚拟环境中的Python...")
        
        # 尝试使用虚拟环境的Python重新执行
        try:
            subprocess.run([venv_python, __file__] + sys.argv[1:])
            sys.exit(0)
        except Exception as e:
            print(f"使用虚拟环境失败: {e}")
            print()
    
    return False

# 尝试导入必要的模块，如果失败则提供有用的错误信息
try:
    from src.codemcp.cli.console import InteractiveConsole
    from src.codemcp.cli.main import app as codemcp_app
    import typer
except ImportError as e:
    # 首先尝试使用虚拟环境
    if check_and_use_venv():
        # 如果check_and_use_venv成功，它已经退出程序
        pass
    
    # 检查是否是缺少依赖
    if "prompt_toolkit" in str(e):
        print("错误: 缺少必要的依赖包 'prompt_toolkit'")
        print("请确保已激活虚拟环境并安装所有依赖:")
        print("  1. 激活虚拟环境: source venv/bin/activate")
        print("  2. 安装依赖: pip install -e .")
        print("  3. 重新运行: ./bin/code-shell")
        print()
        print("或者直接使用虚拟环境中的Python运行:")
        print("  venv/bin/python bin/code-shell")
        
        # 检查虚拟环境是否存在
        venv_path = os.path.join(project_root, "venv")
        if os.path.exists(venv_path):
            print()
            print("检测到虚拟环境存在，但可能未激活或依赖未安装。")
            print("尝试运行: pip install -e .")
    else:
        print(f"导入错误: {e}")
        print("请确保已正确安装CodeMCP及其所有依赖")
    sys.exit(1)


class CodeShell:
    """CodeMCP交互式shell"""
    
    def __init__(self):
        self.history_file = os.path.expanduser("~/.code_shell_history")
        self.setup_readline()
        
        # 命令列表
        self.commands = {
            "help": self.cmd_help,
            "exit": self.cmd_exit,
            "quit": self.cmd_exit,
            "clear": self.cmd_clear,
            "version": self.cmd_version,
            "tasks": self.cmd_tasks,
            "status": self.cmd_status,
            "monitor": self.cmd_monitor,
            "queue": self.cmd_queue,
            "system": self.cmd_system,
            "user": self.cmd_user,
        }
        
        # 帮助信息
        self.help_text = """
CodeMCP Shell - 可用命令:

  基础命令:
    help                    - 显示此帮助信息
    exit, quit              - 退出shell
    clear                   - 清屏
    version                 - 显示版本信息
    
  CodeMCP命令:
    tasks                   - 显示任务列表
    status                  - 显示系统状态
    monitor                 - 启动监控
    queue                   - 队列管理
    system                  - 系统管理
    user                    - 用户管理（创建、登录等）
    
  直接执行:
    输入任何其他命令将尝试作为系统命令执行
    使用 '!' 前缀执行shell命令，如 '!ls -la'
    
  快捷键:
    Ctrl+D                  - 退出
    ↑/↓                     - 命令历史
    Ctrl+C                  - 取消当前命令
"""

    def _check_auth_status(self):
        """检查认证状态，如果认证启用但未配置，提示用户"""
        try:
            # 导入配置
            from src.codemcp.config import settings, ensure_project_config
            
            # 确保配置文件存在
            config_path = ensure_project_config()
            
            # 检查认证是否启用
            if settings.auth_enabled:
                print("🔐 认证检查...")
                
                # 检查配置文件中的token
                import re
                with open(config_path, 'r', encoding='utf-8') as f:
                    content = f.read()
                
                # 查找管理员token
                token_match = re.search(r'USER_TOKEN_ADMIN=(\S+)', content)
                
                if not token_match:
                    print("⚠️  认证已启用，但未检测到管理员token")
                    print("   您需要先登录管理员账户才能使用完整功能")
                    print()
                    print("   请运行以下命令登录:")
                    print("     user login admin <密码>")
                    print("   或")
                    print("     codemcp user login")
                    print()
                    print("   提示: 默认管理员密码为 'admin123'")
                    print("   登录后请立即修改默认密码!")
                    print()
                    
                    # 检查是否要立即登录
                    response = input("是否立即登录? (y/N): ").strip().lower()
                    if response == 'y' or response == 'yes':
                        print()
                        print("请使用以下命令登录:")
                        print("  user login admin admin123")
                        print("然后运行 'user change-password' 修改密码")
                        print()
                else:
                    admin_token = token_match.group(1)
                    # 简单验证token格式
                    if len(admin_token) > 20:
                        print("✅ 检测到有效的管理员token")
                    else:
                        print("⚠️  检测到管理员token，但格式可能无效")
        except Exception as e:
            # 如果检查失败，继续运行但不中断
            print(f"⚠️  认证检查失败: {e}")
            print("将继续以受限模式运行...")
            print()

    def setup_readline(self):
        """设置readline历史记录"""
        try:
            readline.read_history_file(self.history_file)
        except FileNotFoundError:
            pass
        atexit.register(readline.write_history_file, self.history_file)
        
        # 设置Tab补全
        readline.parse_and_bind("tab: complete")
        readline.set_completer(self.completer)

    def completer(self, text, state):
        """命令补全器"""
        options = [cmd for cmd in self.commands.keys() if cmd.startswith(text)]
        if state < len(options):
            return options[state]
        return None

    def cmd_help(self, args: List[str]) -> None:
        """显示帮助信息"""
        print(self.help_text)

    def cmd_exit(self, args: List[str]) -> bool:
        """退出shell"""
        print("再见!")
        return True

    def cmd_clear(self, args: List[str]) -> None:
        """清屏"""
        os.system("clear" if os.name != "nt" else "cls")

    def cmd_version(self, args: List[str]) -> None:
        """显示版本信息"""
        try:
            from src.codemcp import __version__
            print(f"CodeMCP 版本: {__version__}")
        except ImportError:
            print("CodeMCP 版本: 未知")

    def cmd_tasks(self, args: List[str]) -> None:
        """显示任务列表"""
        print("任务列表功能")
        print("使用 'codemcp task list' 查看详细任务信息")

    def cmd_status(self, args: List[str]) -> None:
        """显示系统状态"""
        print("系统状态功能")
        print("使用 'codemcp status' 查看详细系统状态")

    def cmd_monitor(self, args: List[str]) -> None:
        """启动监控"""
        print("监控功能")
        print("使用 'codemcp monitor' 启动详细监控")

    def cmd_queue(self, args: List[str]) -> None:
        """队列管理"""
        print("队列管理功能")
        print("使用 'codemcp queue' 管理任务队列")

    def cmd_system(self, args: List[str]) -> None:
        """系统管理"""
        print("系统管理功能")
        print("使用 'codemcp system' 管理系统配置")

    def cmd_user(self, args: List[str]) -> None:
        """用户管理命令"""
        if not args:
            print("用户管理命令:")
            print("  用法: user <子命令> [参数]")
            print("  可用子命令:")
            print("    create <用户名> [邮箱] [密码] - 创建新用户")
            print("    login <用户名> <密码>        - 用户登录")
            print("    info                         - 显示当前用户信息")
            print("    list                         - 列出所有用户")
            print("    help                         - 显示此帮助")
            return
        
        subcommand = args[0].lower()
        
        if subcommand == "create":
            self._user_create(args[1:])
        elif subcommand == "login":
            self._user_login(args[1:])
        elif subcommand == "info":
            self._user_info(args[1:])
        elif subcommand == "list":
            self._user_list(args[1:])
        elif subcommand == "help":
            print("用户管理命令:")
            print("  用法: user <子命令> [参数]")
            print("  可用子命令:")
            print("    create <用户名> [邮箱] [密码] - 创建新用户")
            print("    login <用户名> <密码>        - 用户登录")
            print("    info                         - 显示当前用户信息")
            print("    list                         - 列出所有用户")
        else:
            print(f"未知的子命令: {subcommand}")
            print("使用 'user help' 查看可用命令")

    def _user_create(self, args: List[str]) -> None:
        """创建用户（已禁用 - 系统只支持管理员账户）"""
        print("❌ 系统只支持一个管理员账户，无法创建新用户")
        print("")
        print("要登录管理员账户，请运行:")
        print("  codemcp user login")
        print("  或")
        print("  user login admin <密码>")

    def _user_login(self, args: List[str]) -> None:
        """管理员登录"""
        if len(args) < 2:
            print("错误: 需要管理员用户名和密码")
            print("用法: user login admin <密码>")
            print("")
            print("注意: 系统只支持管理员账户")
            return
        
        username = args[0]
        password = args[1]
        
        if username != "admin":
            print("❌ 错误: 系统只支持管理员账户")
            print("请使用 'admin' 作为用户名")
            print("")
            print("用法: user login admin <密码>")
            return
        
        print(f"尝试登录管理员账户: {username}")
        
        try:
            # 尝试使用API进行登录
            from src.codemcp.cli.api_client import get_api_manager
            import asyncio
            
            manager = get_api_manager()
            
            if manager.test_connection():
                print("连接到API服务器...")
                # 这里可以添加实际的API登录调用
                # 暂时使用模拟成功
                print(f"✅ 管理员登录成功 (模拟)")
                print(f"欢迎, {username}!")
                print("")
                print("提示: 要使用完整的登录功能，请运行:")
                print("  codemcp user login")
                print("  或")
                print("  codemcp --init-admin (首次初始化)")
            else:
                print("❌ API服务器未连接，无法登录")
                print("提示: 请确保CodeMCP服务器正在运行")
                print("")
                print("要启动服务器，请运行:")
                print("  codemcp-server")
                
        except Exception as e:
            print(f"❌ 登录时出错: {e}")
            print("显示模拟登录成功:")
            print(f"✅ 管理员登录成功 (模拟)")
            print(f"欢迎, {username}!")
    
    def _user_info(self, args: List[str]) -> None:
        """显示当前用户信息"""
        print("获取当前用户信息...")
        
        try:
            # 检查当前目录配置文件
            import os
            from pathlib import Path
            
            current_dir = Path.cwd()
            config_file = current_dir / ".codemcp"
            
            if config_file.exists():
                print("当前目录配置文件:")
                with open(config_file, 'r', encoding='utf-8') as f:
                    for line in f:
                        if line.strip() and not line.startswith('#'):
                            print(f"  {line.strip()}")
            else:
                print("当前目录没有配置文件")
            
            # 尝试从API获取用户信息
            try:
                from src.codemcp.cli.api_client import get_api_manager
                manager = get_api_manager()
                
                if manager.test_connection():
                    print("\nAPI服务器用户信息:")
                    # 这里可以添加获取用户信息的API调用
                    print("  (用户信息API端点尚未实现)")
                else:
                    print("\nAPI服务器未连接")
            except Exception as e:
                print(f"\n获取API用户信息失败: {e}")
                
        except Exception as e:
            print(f"获取用户信息时出错: {e}")
    
    def _user_list(self, args: List[str]) -> None:
        """列出用户（系统只支持管理员账户）"""
        print("系统用户列表:")
        print("")
        print("当前系统只支持一个管理员账户:")
        print("  1. admin (admin@example.com) - 超级用户")
        print("")
        print("要查看管理员详细信息，请运行:")
        print("  codemcp user info")
        print("")
        print("要登录管理员账户，请运行:")
        print("  codemcp user login")

    def execute_system_command(self, command: str) -> None:
        """执行系统命令"""
        if command.startswith('!'):
            # 执行shell命令
            shell_cmd = command[1:].strip()
            if shell_cmd:
                print(f"执行: {shell_cmd}")
                os.system(shell_cmd)
            else:
                print("错误: 请输入有效的shell命令")
        else:
            # 尝试作为系统命令执行
            print(f"执行系统命令: {command}")
            os.system(command)
    
    def process_command(self, command: str) -> bool:
        """处理命令"""
        command = command.strip()
        if not command:
            return False
        
        # 分割命令和参数
        parts = command.split()
        cmd = parts[0].lower()
        args = parts[1:]
        
        # 检查是否是内置命令
        if cmd in self.commands:
            handler = self.commands[cmd]
            if cmd in ["exit", "quit"]:
                return handler(args)
            else:
                handler(args)
        else:
            # 尝试执行系统命令
            self.execute_system_command(command)
        
        return False
    
    def run(self):
        """运行交互式shell"""
        # 检查认证状态
        self._check_auth_status()
        
        print("=" * 60)
        print("CodeMCP Shell - 交互式命令执行环境")
        print("输入 'help' 查看可用命令")
        print("输入 'exit' 或 'quit' 退出")
        print("=" * 60)
        print()
        
        while True:
            try:
                # 显示提示符
                prompt = "code-shell> "
                try:
                    command = input(prompt)
                except EOFError:
                    print()  # 换行
                    break
                
                # 处理命令
                should_exit = self.process_command(command)
                if should_exit:
                    break
                    
            except KeyboardInterrupt:
                print("\n输入 'exit' 或 'quit' 退出")
            except Exception as e:
                print(f"错误: {e}")


def main():
    """主函数"""
    shell = CodeShell()
    shell.run()


if __name__ == "__main__":
    main()