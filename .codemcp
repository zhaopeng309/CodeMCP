# CodeMCP 项目级配置文件
# 文件名: .codemcp
# 优先级: 当前目录 > 安装目录 (CODEMCP_HOME)
# 
# 将此文件复制到项目目录并重命名为 .codemcp，然后根据需要进行修改。
# CLI 工具启动时会自动检查当前目录是否有 .codemcp 文件，
# 如果没有，会自动从安装目录拷贝一个到当前目录。

# ============================================
# 认证配置
# ============================================

# 是否启用认证
# 如果禁用 (false)，所有 API 都不需要认证
# 如果启用 (true)，需要 JWT 令牌才能访问 API
# 默认值: true
AUTH_ENABLED=true

# JWT 密钥 (当 AUTH_ENABLED=true 时生效)
# 生产环境必须修改此值！
# 生成安全密钥: openssl rand -hex 32
SECRET_KEY=1a849eebf613a4dd214a1f5447433a9a78ead1a499ef854edc58b0b8cd1d27b4

# JWT 算法 (当 AUTH_ENABLED=true 时生效)
# 支持: HS256, HS384, HS512
JWT_ALGORITHM=HS256

# 初始管理员账户 (当 AUTH_ENABLED=true 时生效)
# 首次启动时自动创建管理员用户
# ⚠️  安全警告: 默认密码 'admin123' 极易被猜测!
#     首次登录后必须立即修改密码!
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123
INIT_ADMIN_EMAIL=admin@example.com

# ============================================
# 数据库配置
# ============================================

# 数据库连接 URL
# 支持 SQLite、PostgreSQL、MySQL 等
# 示例: sqlite:///./codemcp.db
# 示例: postgresql://user:password@localhost:5432/codemcp
DATABASE_URL=sqlite:///./codemcp.db

# ============================================
# 服务器配置
# ============================================

# 服务器监听地址
HOST=0.0.0.0

# 服务器监听端口
PORT=8000

# 调试模式
DEBUG=false

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# API 配置
# ============================================

# API 前缀
API_PREFIX=/api/v1

# CORS 允许的来源
# 多个用逗号分隔或 JSON 数组格式
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ============================================
# 任务执行配置
# ============================================

# 任务窗口大小 (同时执行的最大任务数)
TASK_WINDOW_SIZE=5

# 最大重试次数
MAX_RETRIES=3

# 默认优先级
DEFAULT_PRIORITY=0

# ============================================
# 日志配置
# ============================================

# 日志文件路径 (可选，留空则输出到控制台)
# LOG_FILE=/var/log/codemcp/app.log

# 日志格式: json 或 text
LOG_FORMAT=json

# ============================================
# MCP 服务器配置 (可选)
# ============================================

# MCP Planner 服务器地址
# MCP_PLANNER_URL=http://localhost:8001

# MCP Executor 服务器地址
# MCP_EXECUTOR_URL=http://localhost:8002

# ============================================
# CLI 工具配置 (项目级覆盖)
# ============================================

# API 服务器地址 (CLI 工具使用)
# API_BASE_URL=http://localhost:8000

# API 超时时间 (秒)
# API_TIMEOUT=30.0

# 认证令牌 (CLI 工具使用，通过登录获取)
# AUTH_TOKEN=your-jwt-token-here

# ============================================
# 使用说明
# ============================================
#
# 1. 将此文件复制到项目目录并重命名为 .codemcp
# 2. 根据项目需求修改配置值
# 3. 启动 CLI 工具时会自动加载此配置
# 4. 配置优先级: 当前目录 .codemcp > 安装目录 .codemcp
# 5. 项目级配置会覆盖全局配置
#
# 示例使用场景:
# - 不同项目使用不同的数据库
# - 不同项目使用不同的认证配置
# - 不同项目连接到不同的 API 服务器
# - 项目团队成员共享相同的项目配置
#
# 注意: 敏感信息 (如密码、密钥) 不应提交到版本控制系统
# 建议将 .codemcp 添加到 .gitignore 文件
